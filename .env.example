# ═══════════════════════════════════════════════════════════
# OMNI DOWNLOADER — Netlify Environment Variables (copy all)
# ═══════════════════════════════════════════════════════════

# REQUIRED — All-in-One download API key (Social Download All In One)
DOWNLOAD_API_KEY=your_download_api_key
# Legacy alias (still works if DOWNLOAD_API_KEY is empty)
RAPIDAPI_KEY=

# REQUIRED — admin panel login (/admin)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_strong_password
ADMIN_JWT_SECRET=random_secret_string
SESSION_SECRET=random_session_secret

# Plan tier: free (default) | starter (when you upgrade — limits auto-update)
OMNI_PLAN_TIER=free

# Free tier limits (auto from OMNI_PLAN_TIER — optional override)
RAPIDAPI_MONTHLY_LIMIT=100
NETLIFY_BANDWIDTH_LIMIT_MB=102400
UPSTASH_STORAGE_LIMIT_MB=256

# Domain (no custom domain yet)
DOMAIN_NAME=omnidownloader.netlify.app
DOMAIN_PURCHASED=false
DOMAIN_REGISTRAR=Not purchased yet

# REQUIRED for live Netlify bandwidth in admin
NETLIFY_ACCESS_TOKEN=your_netlify_pat
NETLIFY_SITE_ID=your_site_uuid

# REQUIRED for persistent admin stats on live site
# Upstash console → your database → REST API tab (NOT the redis:// TCP link)
UPSTASH_REDIS_REST_URL=https://your-db-xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxxxx...

# Link cache — saves RapidAPI calls (uses Upstash when configured)
LINK_CACHE_TTL_SEC=14400
LINK_RATE_LIMIT_PER_HOUR=30

# Optional — seed RapidAPI used count if headers unavailable (check rapidapi.com → Billing → Usage)
# RAPIDAPI_USAGE_BASELINE=42

# When you buy custom domain later:
# DOMAIN_PURCHASED=true
# DOMAIN_NAME=yourdomain.com
# DOMAIN_REGISTRAR=Namecheap
# DOMAIN_EXPIRES=2027-12-31

# When you upgrade RapidAPI / Netlify:
# OMNI_PLAN_TIER=starter
# RAPIDAPI_MONTHLY_LIMIT=500
# NETLIFY_BANDWIDTH_LIMIT_MB=512000
